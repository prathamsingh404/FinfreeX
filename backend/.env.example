# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_KEY=your-anon-key             # also called anon key for local access

# LLM (use at least one)
GROQ_API_KEY=your-groq-key
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Free APIs
ALPHA_VANTAGE_API_KEY=your-free-key   # 500 req/day free at alphavantage.co
NEWS_API_KEY=your-free-key            # 100 req/day free at newsapi.org
FINNHUB_KEY=your-free-key
FRED_KEY=your-free-key

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# App config
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
REDIS_URL=redis://localhost:6379      # for caching (optional in dev)

# Broker Integration (Optional)
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
